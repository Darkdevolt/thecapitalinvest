{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["api/lib/**/*"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/nav.js", "dest": "/public/nav.js" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization,Content-Type,X-Requested-With" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ]
}
