{
  "version": 2,
  "rewrites": [
    { "source": "/api/boc", "destination": "/api/data?endpoint=boc" },
    { "source": "/api/fiche", "destination": "/api/data?endpoint=fiche" },
    { "source": "/api/marche", "destination": "/api/data?endpoint=marche" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/nav.js", "destination": "/public/nav.js" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/admin", "destination": "/public/admin.html" },
    { "source": "/:path*.html", "destination": "/public/:path*.html" },
    { "source": "/", "destination": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization,Content-Type,X-Requested-With" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ],
  "functions": {
    "api/data.js": { "maxDuration": 10 },
    "api/admin.js": { "maxDuration": 10 },
    "api/auth.js": { "maxDuration": 10 },
    "api/contact.js": { "maxDuration": 10 },
    "api/scraper.js": { "maxDuration": 30 }
  }
}
